OPENAI_MODEL=gpt-4o-mini

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=AC3fde2f4411d730e08eaf8559ce8f0207
#TWILIO_AUTH_TOKEN=d9c00782301b6b8858ba5ccd4d4c95f6
TWILIO_AUTH_TOKEN=d9c00782301b6b8858ba5ccd4d4c95f6
# For Twilio WhatsApp sandbox typically:
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- App ---
APP_TIMEZONE=Europe/Warsaw
CHECK_EVERY_HOURS=1
DEFAULT_THRESHOLD=65
COOLDOWN_MINUTES=0
MAX_TOKENS=160
TEMPERATURE=0.4

# Open-Meteo
OPEN_METEO_FORECAST_HOURS=24
AI_MODE=on
DEFAULT_THRESHOLD_ALLERGY=60

# --- WeatherGuard extra data sources (added by patch 20260216T105652Z) ---
GIOS_MODE=on
GIOS_MAX_DISTANCE_KM=60
IMGW_WARNINGS_MODE=on
SPACE_WEATHER_MODE=on
GOOGLE_POLLEN_MODE=auto
GOOGLE_POLLEN_LANG=pl
GOOGLE_POLLEN_API_KEY=

# --- Twilio SMS ---
TWILIO_CHANNEL=sms
# Set either TWILIO_FROM (Twilio SMS-capable number or Sender ID) OR TWILIO_MESSAGING_SERVICE_SID
TWILIO_FROM=++48732144313
#TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PUBLIC_BASE_URL=https://dev.pracunia.pl
TWILIO_SMS_INBOUND_PATH=/twilio/sms/inbound
DISABLE_TWILIO_SIGNATURE_VALIDATION=0

# Trends delivery over SMS:
# - link: include URL in SMS
# - mms: attach media_url (only if your code passes media_url)
SMS_TRENDS_MODE=link
SMS_TRENDS_BASE_URL=https://dev.pracunia.pl

# Where inbound feedback is logged (JSONL)
SMS_FEEDBACK_LOG=./data/sms_feedback.jsonl

# --- Twilio SMS ---
TWILIO_CHANNEL=sms
# Set either TWILIO_FROM (Twilio SMS-capable number or Sender ID) OR TWILIO_MESSAGING_SERVICE_SID
#TWILIO_FROM=+10000000000
#TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

#PUBLIC_BASE_URL=https://dev.pracunia.pl
#TWILIO_SMS_INBOUND_PATH=/twilio/sms/inbound
#DISABLE_TWILIO_SIGNATURE_VALIDATION=0

# --- SMS gateway (inbound) ---
WG_SMS_WEBHOOK_PORT=5055
SMS_FEEDBACK_LOG=/opt/weatherguard/data/sms_feedback.jsonl
SMS_USERS_DB=/opt/weatherguard/data/sms_users.json

# Legacy webhook (auto-detect tries to set this). Used to preserve old symptom/signal flow.
#LEGACY_WEBHOOK_URL=http://127.0.0.1:XXXX/twilio/whatsapp/inbound

# --- Trends link (TREND command) ---
TRENDS_PUBLIC_DIR=/opt/weatherguard/public_media/trends
TRENDS_PUBLIC_URL_BASE=https://dev.pracunia.pl/weatherguard/trends
TRENDS_GLOB=*.png
